# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored, .env.example is not.

# Gmail address that SENDS the email (typically your own Gmail account)
GMAIL_USER=your.email@gmail.com

# Gmail App Password (NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification on the Google account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where contact form submissions get delivered (can be the same as GMAIL_USER)
CONTACT_TO=your.email@gmail.com
